    {
      "name": "TESTES DO SOUTO",
      "item": [
        {
          "name": "Permissão de Acesso Parcial na Listagem (CT-033)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = null;",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test('Status code é 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta não contém campos ou ações restritas de administração', function () {",
                  "    const forbiddenKeys = ['edit', 'delete', 'admin', 'canEdit', 'canDelete'];",
                  "    const responseText = pm.response.text();",
                  "    forbiddenKeys.forEach((key) => {",
                  "        pm.expect(responseText).to.not.include('\"' + key + '\"');",
                  "    });",
                  "",
                  "    if (jsonData) {",
                  "        const serialized = JSON.stringify(jsonData);",
                  "        forbiddenKeys.forEach((key) => {",
                  "            pm.expect(serialized).to.not.include('\"' + key + '\"');",
                  "        });",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Role",
                "value": "Leitor",
                "disabled": false
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/acervo/livros",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "acervo",
                "livros"
              ]
            },
            "description": "Generated from cURL: curl --request GET 'http://localhost:8080/api/acervo/livros' --header 'X-User-Role: Leitor'"
          },
          "response": []
        },
