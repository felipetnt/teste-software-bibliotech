          "name": "Unicidade de E-mail / E-mail Duplicado (CT-002)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test('Status code é 400 ou 409', function () {",
                  "    pm.expect([400, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Mensagem de erro é E-mail já cadastrado', function () {",
                  "    pm.expect(jsonData.message).to.eql('E-mail já cadastrado');",
                  "});",
                  "",
                  "pm.test('Código de erro é EMAIL_DUPLICADO', function () {",
                  "    pm.expect(jsonData.codigo || jsonData.code || jsonData.erroCodigo).to.eql('EMAIL_DUPLICADO');",
                  "});"
                ]
              }
            }
