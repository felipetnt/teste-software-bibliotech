      "name": "TESTES DO JOÃO GUILHERME",
      "item": [
        {
          "name": "Validação de Formato de E-mail (CT-006)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test('Status code é 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Mensagem é Email inválido', function () {",
                  "    pm.expect(jsonData.message).to.eql('Email inválido');",
                  "});",
                  "",
                  "pm.test('Código de erro é EMAIL_INVALIDO', function () {",
                  "    pm.expect(jsonData.codigo || jsonData.code || jsonData.erroCodigo).to.eql('EMAIL_INVALIDO');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joaoemail.com\",\n  \"senha\": \"SenhaValida@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/api/usuarios/cadastro",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "usuarios",
                "cadastro"
              ]
            }
          },
          "response": []
        },
